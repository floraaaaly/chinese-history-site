[
  {
    "id": "gai-xia-ge",
    "title": "垓下歌",
    "author": "项羽",
    "author_id": "xiang-yu",
    "dynasty": "秦末",
    "form": "楚辞",
    "year": -202,
    "motif": ["功业理想"],
    "lines": [
      "力拔山兮气盖世，",
      "时不利兮骓不逝。",
      "骓不逝兮可奈何，",
      "虞兮虞兮奈若何！"
    ],
    "background": "项羽被汉军围困于垓下，四面楚歌，慷慨悲歌，与虞姬诀别，此后突围，乌江自刎。",
    "related_events": ["chu-han-war"],
    "imagery": ["骓", "虞兮", "力拔山"]
  },
  {
    "id": "duan-ge-xing",
    "title": "短歌行",
    "author": "曹操",
    "author_id": "cao-cao",
    "dynasty": "东汉末",
    "form": "乐府",
    "year": 208,
    "motif": ["时间流逝", "功业理想"],
    "lines": [
      "对酒当歌，人生几何！",
      "譬如朝露，去日苦多。",
      "慨当以慷，忧思难忘。",
      "何以解忧？唯有杜康。",
      "青青子衿，悠悠我心。",
      "但为君故，沉吟至今。",
      "……",
      "山不厌高，海不厌深。",
      "周公吐哺，天下归心。"
    ],
    "background": "赤壁之战前，曹操在长江边宴请众将，慷慨而歌，表达了求贤若渴与统一天下的雄心。",
    "related_events": ["three-kingdoms"],
    "imagery": ["朝露", "杜康", "周公", "山海"]
  },
  {
    "id": "jing-ye-si",
    "title": "静夜思",
    "author": "李白",
    "author_id": "li-bai",
    "dynasty": "唐",
    "form": "五言绝句",
    "year": 726,
    "motif": ["思乡"],
    "lines": [
      "床前明月光，",
      "疑是地上霜。",
      "举头望明月，",
      "低头思故乡。"
    ],
    "background": "李白旅居扬州时所作，借月抒发羁旅之愁与思乡之情，是流传最广的唐诗之一。",
    "related_events": ["tang-flourish"],
    "imagery": ["明月", "霜", "故乡"]
  },
  {
    "id": "chun-wang",
    "title": "春望",
    "author": "杜甫",
    "author_id": "du-fu",
    "dynasty": "唐",
    "form": "五言律诗",
    "year": 757,
    "motif": ["功业理想", "思乡"],
    "lines": [
      "国破山河在，城春草木深。",
      "感时花溅泪，恨别鸟惊心。",
      "烽火连三月，家书抵万金。",
      "白头搔更短，浑欲不胜簪。"
    ],
    "background": "安史之乱中，杜甫被困长安，目睹长安残破，忧国思家，写下此诗。烽火三月，家书难得，道尽乱世之苦。",
    "related_events": ["anshi-rebellion", "tang-flourish"],
    "imagery": ["烽火", "家书", "白头", "国破", "山河"]
  },
  {
    "id": "man-jiang-hong",
    "title": "满江红·写怀",
    "author": "岳飞",
    "author_id": "yue-fei",
    "dynasty": "宋",
    "form": "词",
    "year": 1136,
    "motif": ["功业理想"],
    "lines": [
      "怒发冲冠，凭栏处、潇潇雨歇。",
      "抬望眼，仰天长啸，壮怀激烈。",
      "三十功名尘与土，八千里路云和月。",
      "莫等闲，白了少年头，空悲切！",
      "靖康耻，犹未雪；臣子恨，何时灭！",
      "驾长车，踏破贺兰山缺。",
      "壮志饥餐胡虏肉，笑谈渴饮匈奴血。",
      "待从头、收拾旧山河，朝天阙。"
    ],
    "background": "岳飞北伐途中所作，词中以「靖康耻」为念，表达收复河山的壮志。后因秦桧等人陷害，岳飞以莫须有之罪被害。",
    "related_events": ["jingkang-incident"],
    "imagery": ["怒发冲冠", "靖康耻", "旧山河", "长车", "贺兰山"]
  },
  {
    "id": "sheng-sheng-man",
    "title": "声声慢·寻寻觅觅",
    "author": "李清照",
    "author_id": "li-qingzhao",
    "dynasty": "宋",
    "form": "词",
    "year": 1127,
    "motif": ["孤独", "时间流逝"],
    "lines": [
      "寻寻觅觅，冷冷清清，凄凄惨惨戚戚。",
      "乍暖还寒时候，最难将息。",
      "三杯两盏淡酒，怎敌他、晚来风急！",
      "雁过也，正伤心，却是旧时相识。",
      "满地黄花堆积，憔悴损，如今有谁堪摘？",
      "守着窗儿，独自怎生得黑！",
      "梧桐更兼细雨，到黄昏、点点滴滴。",
      "这次第，怎一个愁字了得！"
    ],
    "background": "靖康之变后，李清照流离南渡，丈夫赵明诚病故，国破家亡，晚年孤苦，此词是其最沉痛的人生写照。",
    "related_events": ["jingkang-incident"],
    "imagery": ["雁", "黄花", "梧桐", "细雨", "黄昏"]
  },
  {
    "id": "yi-shandong-xiongdi",
    "title": "九月九日忆山东兄弟",
    "author": "王维",
    "author_id": "wang-wei",
    "dynasty": "唐",
    "form": "七言绝句",
    "year": 718,
    "motif": ["思乡"],
    "lines": [
      "独在异乡为异客，",
      "每逢佳节倍思亲。",
      "遥知兄弟登高处，",
      "遍插茱萸少一人。"
    ],
    "background": "王维少年时客居长安，重阳佳节思念家乡兄弟而作。「每逢佳节倍思亲」道尽天下游子之心。",
    "related_events": [],
    "imagery": ["茱萸", "异乡", "登高", "佳节"]
  },
  {
    "id": "song-yuan-er",
    "title": "送元二使安西",
    "author": "王维",
    "author_id": "wang-wei",
    "dynasty": "唐",
    "form": "七言绝句",
    "year": 737,
    "motif": ["离别"],
    "lines": [
      "渭城朝雨浥轻尘，",
      "客舍青青柳色新。",
      "劝君更尽一杯酒，",
      "西出阳关无故人。"
    ],
    "background": "友人元二即将远赴西域，王维于渭城设宴饯别。柳色、美酒、阳关，写尽离别的不舍，后谱为《阳关三叠》传唱千古。",
    "related_events": [],
    "imagery": ["柳", "酒", "阳关", "朝雨"]
  },
  {
    "id": "jiang-xue",
    "title": "江雪",
    "author": "柳宗元",
    "author_id": "liu-zongyuan",
    "dynasty": "唐",
    "form": "五言绝句",
    "year": 810,
    "motif": ["孤独"],
    "lines": [
      "千山鸟飞绝，",
      "万径人踪灭。",
      "孤舟蓑笠翁，",
      "独钓寒江雪。"
    ],
    "background": "柳宗元参与永贞革新失败被贬永州，于天地寂灭的雪景中，写下这位独钓寒江的孤舟老翁，正是其孤高不屈的自我写照。",
    "related_events": [],
    "imagery": ["孤舟", "寒江", "雪", "千山"]
  },
  {
    "id": "yin-jiu-wu",
    "title": "饮酒·其五",
    "author": "陶渊明",
    "author_id": "tao-yuanming",
    "dynasty": "东晋",
    "form": "五言古诗",
    "year": 417,
    "motif": ["隐逸"],
    "lines": [
      "结庐在人境，而无车马喧。",
      "问君何能尔？心远地自偏。",
      "采菊东篱下，悠然见南山。",
      "山气日夕佳，飞鸟相与还。",
      "此中有真意，欲辨已忘言。"
    ],
    "background": "陶渊明辞官归隐田园后所作。「采菊东篱下，悠然见南山」道出超然物外、心与自然合一的隐逸境界，为千古田园诗之绝唱。",
    "related_events": [],
    "imagery": ["菊", "南山", "飞鸟", "东篱"]
  },
  {
    "id": "shan-ju-qiu-ming",
    "title": "山居秋暝",
    "author": "王维",
    "author_id": "wang-wei",
    "dynasty": "唐",
    "form": "五言律诗",
    "year": 740,
    "motif": ["隐逸"],
    "lines": [
      "空山新雨后，天气晚来秋。",
      "明月松间照，清泉石上流。",
      "竹喧归浣女，莲动下渔舟。",
      "随意春芳歇，王孙自可留。"
    ],
    "background": "王维隐居辋川时所作。雨后空山、明月清泉、翠竹青莲，一派清新宁静，是「诗中有画」的山水田园典范。",
    "related_events": [],
    "imagery": ["空山", "明月", "松", "清泉", "竹"]
  },
  {
    "id": "mei-hua",
    "title": "梅花",
    "author": "王安石",
    "author_id": "wang-anshi",
    "dynasty": "宋",
    "form": "五言绝句",
    "year": 1078,
    "motif": ["高洁"],
    "lines": [
      "墙角数枝梅，",
      "凌寒独自开。",
      "遥知不是雪，",
      "为有暗香来。"
    ],
    "background": "王安石变法受挫、退居江宁后所作。以墙角凌寒独开的梅花自喻，借暗香写孤高坚贞、不随流俗的品格。",
    "related_events": ["wang-anshi-reform"],
    "imagery": ["梅", "暗香", "凌寒", "雪"]
  },
  {
    "id": "yu-mei-ren",
    "title": "虞美人·春花秋月",
    "author": "李煜",
    "author_id": "li-yu",
    "dynasty": "南唐",
    "form": "词",
    "year": 978,
    "motif": ["时间流逝"],
    "lines": [
      "春花秋月何时了？往事知多少。",
      "小楼昨夜又东风，故国不堪回首月明中。",
      "雕栏玉砌应犹在，只是朱颜改。",
      "问君能有几多愁？恰似一江春水向东流。"
    ],
    "background": "南唐亡国后，李煜被囚于汴京，于故国之思与亡国之痛中写下此词。相传宋太宗读「故国不堪回首」大怒，遂赐毒酒，此词竟成绝命之作。",
    "related_events": [],
    "imagery": ["春花秋月", "春水", "故国", "朱颜", "东风"]
  },
  {
    "id": "chu-sai",
    "title": "出塞",
    "author": "王昌龄",
    "author_id": "wang-changling",
    "dynasty": "唐",
    "form": "七言绝句",
    "year": 724,
    "motif": ["功业理想"],
    "lines": [
      "秦时明月汉时关，",
      "万里长征人未还。",
      "但使龙城飞将在，",
      "不教胡马度阴山。"
    ],
    "background": "盛唐边塞诗的代表作。诗人由秦汉的明月关塞，遥想良将守边、外患不侵的功业理想，气象雄浑，被誉为唐人七绝压卷之作。",
    "related_events": [],
    "imagery": ["明月", "关", "胡马", "阴山", "飞将"]
  },
  {
    "id": "xiang-si",
    "title": "相思",
    "author": "王维",
    "author_id": "wang-wei",
    "dynasty": "唐",
    "form": "五言绝句",
    "year": 730,
    "motif": ["爱情相思"],
    "lines": [
      "红豆生南国，",
      "春来发几枝。",
      "愿君多采撷，",
      "此物最相思。"
    ],
    "background": "王维借生于南国的红豆寄托相思之情。红豆又名相思子，自此成为相思的千古象征，此诗亦名《江上赠李龟年》。",
    "related_events": [],
    "imagery": ["红豆", "相思", "南国", "春"]
  },
  {
    "id": "jin-se",
    "title": "锦瑟",
    "author": "李商隐",
    "author_id": "li-shangyin",
    "dynasty": "唐",
    "form": "七言律诗",
    "year": 858,
    "motif": ["爱情相思", "时间流逝"],
    "lines": [
      "锦瑟无端五十弦，一弦一柱思华年。",
      "庄生晓梦迷蝴蝶，望帝春心托杜鹃。",
      "沧海月明珠有泪，蓝田日暖玉生烟。",
      "此情可待成追忆，只是当时已惘然。"
    ],
    "background": "李商隐最为朦胧难解的名作。借锦瑟、蝴蝶、杜鹃、珠泪诸般意象，追忆似水华年与一段惘然的深情，千载以来众说纷纭。",
    "related_events": [],
    "imagery": ["锦瑟", "蝴蝶", "杜鹃", "珠泪", "华年"]
  }
]
